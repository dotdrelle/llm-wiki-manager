# Shared manager configuration.
# Copy to .env and keep real secrets local.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Shared MCP agent host port.
MAILER_MCP_PORT=3335

# Optional bearer tokens for MCP endpoints.
WIKI_MCP_AUTH_TOKEN=
CME_MCP_AUTH_TOKEN=
MAILER_MCP_AUTH_TOKEN=
PRODUCTION_MCP_AUTH_TOKEN=

# agent-wiki-production behaviour (defaults shown).
# Set PRODUCTION_REQUIRE_CONFIRMATION=false to skip the confirmed=true guard on mutating jobs.
PRODUCTION_REQUIRE_CONFIRMATION=true

# MailerSend action agent.
MAILERSEND_API_KEY=
MAILERSEND_FROM_EMAIL=no-reply@example.com
MAILERSEND_FROM_NAME=Mailer Agent
MAILERSEND_USER_AGENT=curl/8.7.1
MAILER_DRY_RUN=true
