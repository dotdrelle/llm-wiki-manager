# .env — wiki-manager local configuration
#
# Copy this file to .env and fill in your values.
# This file is loaded automatically by wiki-workspace for workspace compose
# and agents compose commands.
#
# NEVER commit .env — it is gitignored.

# ── Paths ──────────────────────────────────────────────────────────────────────

# Root directory that contains all workspace folders.
# Required when using: wiki-workspace agents up/down/logs
WORKSPACES_ROOT=/path/to/workspaces

# Directory for agent persistent state (cme config, document queues).
# Defaults to .agents-data/ next to wiki-workspace.
# AGENTS_DATA_DIR=/path/to/.agents-data

# ── Agent auth tokens ──────────────────────────────────────────────────────────
#
# Each agent has its own bearer token. Set the matching Authorization header
# in mcp.endpoints.json so Donna can call the agent:
#
#   "cme":       { "headers": { "Authorization": "Bearer <CME_MCP_AUTH_TOKEN>" } }
#   "documents": { "headers": { "Authorization": "Bearer <DOCUMENTS_MCP_AUTH_TOKEN>" } }
#
# Leave empty to disable authentication on that agent (not recommended in production).

CME_MCP_AUTH_TOKEN=
DOCUMENTS_MCP_AUTH_TOKEN=

# ── Mailer (MailerSend) ────────────────────────────────────────────────────────


# ── Documents LLM OCR / Mermaid (optional) ─────────────────────────────────────

# All image OCR is delegated to an OpenAI-compatible vision LLM. The default
# Default target is the Albert API (etalab); set DOCUMENT_LLM_API_KEY.
# DOCUMENT_LLM_BASE_URL=https://albert.api.etalab.gouv.fr/v1
# DOCUMENT_LLM_MODEL=LightOnOCR-2-1B
# DOCUMENT_LLM_API_KEY=
# DOCUMENT_LLM_TIMEOUT_SECONDS=120

# ── Optional external MCP providers ────────────────────────────────────────────
# Doctrine: every variable an external MCP endpoint needs (API key, token…)
# lives HERE and is referenced from mcp.endpoints.json as ${VAR_NAME}.
# Add your own entries when you declare additional endpoints.

# ── MCP retry policy (optional) ────────────────────────────────────────────────

# Tool calls are retried on transient HTTP/MCP errors before the run fails.
# WIKI_MANAGER_MCP_RETRY_MAX_ATTEMPTS=2
# WIKI_MANAGER_MCP_RETRY_BACKOFF_MS=500

# ── Runtime evaluator (optional) ───────────────────────────────────────────────

# After a clean agentic runtime run, a second LLM pass checks whether the original
# task was accomplished. Set to 0/false/off/no to disable globally.
# WIKI_MANAGER_EVALUATOR=1

# If evaluator rejects a run or an activity ends in error, the runtime can ask
# the LLM for a partial recovery plan and retry remaining work.
# WIKI_MANAGER_REPLANNER_MAX_REPLANS=2

# Runtime approvals can pause runs or protected tools until /approve is called.
# WIKI_MANAGER_APPROVAL_TIMEOUT_MS=600000
# WIKI_MANAGER_REQUIRE_APPROVAL_TOOLS=production.production_start_job

# ── Agent ports (optional, change only if defaults conflict) ───────────────────

# CME_MCP_PORT=3336
# DOCUMENTS_MCP_PORT=3337
