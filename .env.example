# Shared manager configuration.
# Copy to .env and keep real shared secrets local.
# LLM/vector provider keys are workspace settings; put them in each workspace
# .wikirc.yaml together with that workspace's provider/baseUrl/model.

# External agent-mailer-api MCP endpoint.
MAILER_MCP_PROXY_URL=http://host.docker.internal:3335/mcp/
MAILER_MCP_AUTH_TOKEN=

# agent-wiki-production behaviour.
# Bearer tokens control who can call the agent. This optional extra guard forces
# mutating jobs to include confirm=true after explicit user approval.
PRODUCTION_REQUIRE_CONFIRMATION=false

# External agent-atlassian MCP endpoint.
ATLASSIAN_MCP_PROXY_URL=http://host.docker.internal:9000/mcp
ATLASSIAN_MCP_AUTH_TOKEN=
