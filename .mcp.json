{
  "mcpServers": {
    "agent-cme-wiki": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote@latest",
        "http://localhost:3000/mcp",
        "--allow-http",
        "--transport",
        "http-only"
      ]
    },
    "llm-wiki": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote@latest",
        "http://localhost:3101/mcp",
        "--allow-http",
        "--transport",
        "http-only",
        "--header",
        "Authorization: Bearer dotdrelle"
      ]
    }
  }
}
