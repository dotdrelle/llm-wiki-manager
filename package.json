{
  "name": "@dot/wiki-manager",
  "version": "0.1.0",
  "description": "Agentic shell and orchestration cockpit for llm-wiki workspaces.",
  "license": "PolyForm-Noncommercial-1.0.0",
  "author": "dot",
  "type": "module",
  "bin": {
    "wiki-manager": "bin/wiki-manager.js",
    "wiki-workspace": "wiki-workspace"
  },
  "scripts": {
    "start": "bun ./bin/wiki-manager.js",
    "check": "bun ./bin/wiki-manager.js --version && bun ./bin/wiki-manager.js --help && bun ./bin/wiki-manager.js --once \"verifie le mode agent\""
  },
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.2.0"
  },
  "files": [
    "bin",
    "src",
    "wiki-workspace",
    "docker-compose.yml",
    ".env.example",
    "workspaces/.env.example",
    "README.md",
    "LICENSE",
    "WIKI_MANAGER_AGENT_SHELL.md"
  ],
  "keywords": [
    "llm",
    "wiki",
    "agent",
    "mcp",
    "orchestration",
    "cli"
  ],
  "packageManager": "pnpm@10.29.2",
  "dependencies": {
    "@langchain/langgraph": "^1.3.2",
    "@opentui/core": "^0.3.2",
    "@opentui/solid": "^0.3.2",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "openai": "^6.42.0",
    "solid-js": "1.9.12",
    "yaml": "^2.9.0"
  }
}
