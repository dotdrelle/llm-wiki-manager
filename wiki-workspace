#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="${WIKI_WORKSPACES_FILE:-$ROOT_DIR/workspaces.yaml}"

usage() {
  cat <<'EOF'
Usage:
  ./wiki-workspace wiki <workspace> <command> [args...]
  ./wiki-workspace list
  ./wiki-workspace cme <up|down|logs>
  ./wiki-workspace mailer <up|down|logs>

Commands:
  list                              List configured workspaces
  cme up                            Start the shared agent-cme MCP server
  cme down                          Stop the shared agent-cme MCP server
  cme logs [args...]                Follow agent-cme MCP logs (tail 100 by default)
  mailer up                         Start the shared agent-mailer-api MCP server
  mailer down                       Stop the shared agent-mailer-api MCP server
  mailer logs [args...]             Follow agent-mailer-api logs (tail 100 by default)
  wiki <workspace> init             Initialize the workspace with wiki init
  wiki <workspace> up               Start llm-wiki serve + mcp-http for this workspace
  wiki <workspace> down             Stop serve + mcp-http for this workspace
  wiki <workspace> logs [args...]   Follow workspace serve + mcp-http logs (tail 100 by default)
  wiki <workspace> serve [--open]   Start the web UI (foreground, port from workspaces.yaml; --open launches browser in app mode)
  wiki <workspace> doctor           Run wiki doctor
  wiki <workspace> copy             Copy agent-cme exports into raw/untracked
  wiki <workspace> ingest           Run wiki ingest
  wiki <workspace> build            Run wiki build
  wiki <workspace> export           Run wiki export
  wiki <workspace> run <args...>    Run arbitrary wiki CLI args

Configuration:
  workspaces.yaml at repository root, or WIKI_WORKSPACES_FILE=/path/to/file.
EOF
}

die() {
  printf 'Error: %s\n' "$*" >&2
  exit 1
}

normalize_path() {
  local value="$1"
  if command -v wslpath >/dev/null 2>&1 && [[ "$value" =~ ^[A-Za-z]:[\\/] ]]; then
    wslpath -u "$value"
    return
  fi
  printf '%s\n' "$value"
}

absolute_path() {
  local value="$1"
  value="$(normalize_path "$value")"
  if [[ "$value" = /* ]]; then
    printf '%s\n' "$value"
  else
    printf '%s\n' "$ROOT_DIR/$value"
  fi
}

need_config() {
  [[ -f "$CONFIG_FILE" ]] || die "missing config file: $CONFIG_FILE"
}

yaml_value() {
  local workspace="$1"
  local expr="$2"
  ruby -ryaml -e '
    begin
      file, workspace, expr = ARGV
      data = YAML.load_file(file)
      node = data.fetch("workspaces").fetch(workspace)
      expr.split(".").each { |part| node = node.fetch(part) }
      puts node
    rescue KeyError => e
      warn "missing workspaces.yaml value for workspace=#{workspace}: #{expr} (#{e.message})"
      exit 1
    end
  ' "$CONFIG_FILE" "$workspace" "$expr"
}

list_workspaces() {
  ruby -ryaml -e '
    begin
      file = ARGV.fetch(0)
      data = YAML.load_file(file)
      workspaces = data.fetch("workspaces")
      workspaces.each do |name, ws|
        path = ws["path"] || "-"
        serve = ws["servePort"] || "-"
        mcp = ws["mcpPort"] || "-"
        imports = Array(ws["imports"]).length
        puts "#{name}\tpath=#{path}\tserve=#{serve}\tmcp=#{mcp}\timports=#{imports}"
      end
    rescue KeyError => e
      warn "missing workspaces.yaml value (#{e.message})"
      exit 1
    end
  ' "$CONFIG_FILE"
}

import_paths() {
  local workspace="$1"
  ruby -ryaml -e '
    begin
      file, workspace = ARGV
      data = YAML.load_file(file)
      ws = data.fetch("workspaces").fetch(workspace)
      imports = ws["imports"]
      exit 0 if imports.nil?
      Array(imports).each do |entry|
        unless entry.is_a?(String)
          warn "imports entries must be paths, got: #{entry.inspect}"
          exit 1
        end
        puts entry
      end
    rescue KeyError => e
      warn "missing imports for workspace=#{workspace} (#{e.message})"
      exit 1
    end
  ' "$CONFIG_FILE" "$workspace"
}

compose_project() {
  local workspace="$1"
  printf 'wiki-%s' "$workspace" | tr -c '[:alnum:]_-' '-'
}

compose_for_workspace() {
  local workspace="$1"
  shift
  local ws_path serve_port mcp_port project
  ws_path="$(normalize_path "$(yaml_value "$workspace" path)")"
  serve_port="$(yaml_value "$workspace" servePort)"
  mcp_port="$(yaml_value "$workspace" mcpPort)"
  project="$(compose_project "$workspace")"

  WIKI_WORKSPACE="$ws_path" \
  WIKI_SERVE_PORT="$serve_port" \
  WIKI_MCP_HTTP_PORT="$mcp_port" \
  docker compose -f "$ROOT_DIR/docker-compose.yml" -p "$project" "$@"
}

compose_for_cme() {
  docker compose -f "$ROOT_DIR/docker-compose.yml" -p wikillm-cme "$@"
}

compose_for_mailer() {
  docker compose -f "$ROOT_DIR/docker-compose.yml" -p wikillm-mailer "$@"
}

logs_args() {
  if [[ $# -eq 0 ]]; then
    printf '%s\n' --tail=100 -f
  else
    printf '%s\n' "$@"
  fi
}

run_wiki() {
  local workspace="$1"
  shift
  compose_for_workspace "$workspace" run --rm wiki "$@"
}

open_app_mode() {
  local url="$1"
  case "$(uname -s)" in
    Darwin)
      open -na "Google Chrome" --args "--app=${url}" 2>/dev/null \
        || open -na "Microsoft Edge" --args "--app=${url}" 2>/dev/null \
        || open -a Safari "${url}" 2>/dev/null \
        || open "${url}"
      ;;
    Linux)
      for candidate in google-chrome google-chrome-stable chromium chromium-browser microsoft-edge microsoft-edge-stable; do
        if command -v "$candidate" >/dev/null 2>&1; then
          "$candidate" "--app=${url}" &
          return
        fi
      done
      xdg-open "${url}" 2>/dev/null || true
      ;;
    MINGW*|MSYS*|CYGWIN*)
      for candidate in \
        "C:/Program Files/Google/Chrome/Application/chrome.exe" \
        "C:/Program Files (x86)/Google/Chrome/Application/chrome.exe" \
        "C:/Program Files (x86)/Microsoft/Edge/Application/msedge.exe" \
        "C:/Program Files/Microsoft/Edge/Application/msedge.exe"; do
        if [[ -f "$candidate" ]]; then
          "$candidate" "--app=${url}" &
          return
        fi
      done
      start "" "${url}" || true
      ;;
  esac
}

wait_and_open() {
  local url="$1"
  local max_attempts=30
  local i=0
  while (( i < max_attempts )); do
    sleep 1
    if curl -sf "${url}" >/dev/null 2>&1; then
      open_app_mode "${url}"
      return
    fi
    (( i++ )) || true
  done
  printf 'wiki-workspace: server did not become ready at %s after %ds, opening anyway\n' "${url}" "$max_attempts" >&2
  open_app_mode "${url}"
}

copy_one_export() {
  local workspace="$1"
  local export_path="$2"
  local ws_path source_abs target_abs

  ws_path="$(normalize_path "$(yaml_value "$workspace" path)")"

  source_abs="$(absolute_path "$export_path")"
  target_abs="$ws_path/raw/untracked"

  [[ -d "$source_abs" ]] || die "export path is not a directory: $source_abs"
  mkdir -p "$target_abs"

  if command -v rsync >/dev/null 2>&1; then
    rsync -a --include='*/' --include='*.md' --exclude='*' "$source_abs/" "$target_abs/"
  else
    find "$source_abs" -type f -name '*.md' -print0 | while IFS= read -r -d '' file; do
      rel="${file#"$source_abs"/}"
      mkdir -p "$target_abs/$(dirname "$rel")"
      cp "$file" "$target_abs/$rel"
    done
  fi

  printf 'Copied %s -> %s\n' "$source_abs" "$target_abs"
}

copy_exports() {
  local workspace="$1"
  local count=0
  local configured_imports=()
  while IFS= read -r export_path; do
    [[ -n "$export_path" ]] || continue
    configured_imports+=("$export_path")
  done < <(import_paths "$workspace")

  if [[ "${#configured_imports[@]}" -eq 0 ]]; then
    printf 'No imports configured for workspace: %s\n' "$workspace"
    return 0
  fi

  for export_path in "${configured_imports[@]}"; do
    copy_one_export "$workspace" "$export_path"
    count=$((count + 1))
  done
}

main() {
  if [[ $# -eq 1 && "$1" =~ ^(-h|--help|help)$ ]]; then
    usage
    exit 0
  fi

  if [[ $# -eq 1 && "$1" == "list" ]]; then
    need_config
    list_workspaces
    exit 0
  fi

  if [[ $# -ge 2 && "$1" == "cme" ]]; then
    local cme_command="$2"
    shift 2
    case "$cme_command" in
      up)
        [[ $# -eq 0 ]] || die "cme up does not take arguments"
        compose_for_cme up -d cme-mcp
        ;;
      down)
        [[ $# -eq 0 ]] || die "cme down does not take arguments"
        compose_for_cme stop cme-mcp
        ;;
      logs)
        mapfile -t log_args < <(logs_args "$@")
        compose_for_cme logs "${log_args[@]}" cme-mcp
        ;;
      *)
        die "unknown cme command: $cme_command"
        ;;
    esac
    exit 0
  fi

  if [[ $# -ge 2 && "$1" == "mailer" ]]; then
    local mailer_command="$2"
    shift 2
    case "$mailer_command" in
      up)
        [[ $# -eq 0 ]] || die "mailer up does not take arguments"
        compose_for_mailer up -d mailer-mcp
        ;;
      down)
        [[ $# -eq 0 ]] || die "mailer down does not take arguments"
        compose_for_mailer stop mailer-mcp
        ;;
      logs)
        mapfile -t log_args < <(logs_args "$@")
        compose_for_mailer logs "${log_args[@]}" mailer-mcp
        ;;
      *)
        die "unknown mailer command: $mailer_command"
        ;;
    esac
    exit 0
  fi

  [[ $# -ge 2 ]] || { usage; exit 2; }
  need_config

  local scope="$1"
  [[ "$scope" == "wiki" ]] || die "unknown scope: $scope (expected: wiki, cme, mailer, or list)"
  shift
  [[ $# -ge 2 ]] || die "wiki requires a workspace and a command"

  local workspace="$1"
  local command="$2"
  shift 2

  case "$command" in
    init)
      run_wiki "$workspace" init "$@"
      ;;
    up)
      compose_for_workspace "$workspace" up -d serve mcp-http
      compose_for_cme up -d cme-mcp
      compose_for_mailer up -d mailer-mcp
      ;;
    down)
      compose_for_workspace "$workspace" down
      ;;
    logs)
      mapfile -t log_args < <(logs_args "$@")
      compose_for_workspace "$workspace" logs "${log_args[@]}" serve mcp-http
      ;;
    serve)
      local open_browser=0
      if [[ $# -eq 1 && "$1" == "--open" ]]; then
        open_browser=1
      elif [[ $# -ne 0 ]]; then
        die "serve accepts only --open as optional flag; port is configured in workspaces.yaml"
      fi
      printf 'Starting mcp-http...\n'
      compose_for_workspace "$workspace" up -d mcp-http
      printf 'Starting cme-mcp...\n'
      compose_for_cme up -d cme-mcp
      printf 'Starting mailer-mcp...\n'
      compose_for_mailer up -d mailer-mcp
      if [[ $open_browser -eq 1 ]]; then
        local serve_port
        serve_port="$(yaml_value "$workspace" servePort)"
        wait_and_open "http://localhost:${serve_port}" &
      fi
      compose_for_workspace "$workspace" up serve
      ;;
    doctor|ingest|build|export)
      run_wiki "$workspace" "$command" "$@"
      ;;
    copy)
      [[ $# -eq 0 ]] || die "copy does not take an import name; it copies all configured exports for the workspace"
      copy_exports "$workspace"
      ;;
    run)
      [[ $# -gt 0 ]] || die "run requires wiki CLI args"
      run_wiki "$workspace" "$@"
      ;;
    -h|--help|help)
      usage
      ;;
    *)
      die "unknown command: $command"
      ;;
  esac
}

main "$@"
