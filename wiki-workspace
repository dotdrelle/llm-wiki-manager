#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WORKSPACES_DIR="${WIKI_WORKSPACES_DIR:-$ROOT_DIR/workspaces}"
MANAGER_ENV_FILE="${WIKI_MANAGER_ENV_FILE:-$ROOT_DIR/.env}"

usage() {
  cat <<'EOF'
Usage:
  ./wiki-workspace wiki <workspace> <command> [args...]
  ./wiki-workspace list
  ./wiki-workspace cme <up|down|logs>
  ./wiki-workspace mailer <up|down|logs>

Commands:
  list                              List configured workspaces
  cme up                            Start the shared agent-cme MCP server
  cme down                          Stop the shared agent-cme MCP server
  cme logs [args...]                Follow agent-cme MCP logs (tail 100 by default)
  mailer up                         Start the shared agent-mailer-api MCP server
  mailer down                       Stop the shared agent-mailer-api MCP server
  mailer logs [args...]             Follow agent-mailer-api logs (tail 100 by default)
  wiki <workspace> init             Initialize the workspace with wiki init
  wiki <workspace> up               Start llm-wiki serve + mcp-http for this workspace
  wiki <workspace> down             Stop serve + mcp-http + production-mcp for this workspace
  wiki <workspace> logs [args...]   Follow workspace serve + mcp-http + production-mcp logs (tail 100 by default)
  wiki <workspace> serve [--open]   Start the web UI (foreground, port from workspaces/<name>.env; --open launches browser in app mode)
  wiki <workspace> doctor           Run wiki doctor
  wiki <workspace> copy             Copy agent-cme exports into raw/untracked
  wiki <workspace> ingest           Run wiki ingest
  wiki <workspace> build            Run wiki build
  wiki <workspace> export           Run wiki export
  wiki <workspace> run <args...>    Run arbitrary wiki CLI args

Configuration:
  workspaces/<workspace>.env at repository root, or WIKI_WORKSPACES_DIR=/path/to/dir.
EOF
}

die() {
  printf 'Error: %s\n' "$*" >&2
  exit 1
}

normalize_path() {
  local value="$1"
  if command -v wslpath >/dev/null 2>&1 && [[ "$value" =~ ^[A-Za-z]:[\\/] ]]; then
    wslpath -u "$value"
    return
  fi
  printf '%s\n' "$value"
}

absolute_path() {
  local value="$1"
  value="$(normalize_path "$value")"
  if [[ "$value" = /* ]]; then
    printf '%s\n' "$value"
  else
    printf '%s\n' "$ROOT_DIR/$value"
  fi
}

workspace_env_file() {
  local workspace="$1"
  printf '%s/%s.env\n' "$WORKSPACES_DIR" "$workspace"
}

need_workspace_env() {
  local workspace="$1"
  local file
  file="$(workspace_env_file "$workspace")"
  [[ -f "$file" ]] || die "missing workspace env file: $file"
}

env_value() {
  local file="$1"
  local key="$2"
  local default="${3-}"
  local line value
  [[ -f "$file" ]] || { printf '%s\n' "$default"; return 0; }
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line%$'\r'}"
    [[ "$line" == "$key="* ]] || continue
    value="${line#*=}"
    if [[ "$value" == \"*\" && "$value" == *\" ]]; then
      value="${value:1:${#value}-2}"
    elif [[ "$value" == \'*\' && "$value" == *\' ]]; then
      value="${value:1:${#value}-2}"
    fi
    printf '%s\n' "$value"
    return 0
  done < "$file"
  printf '%s\n' "$default"
}

workspace_value() {
  local workspace="$1"
  local key="$2"
  local default="${3-}"
  env_value "$(workspace_env_file "$workspace")" "$key" "$default"
}

list_workspaces() {
  [[ -d "$WORKSPACES_DIR" ]] || die "missing workspaces directory: $WORKSPACES_DIR"
  local found=0
  local file name path serve mcp imports count
  for file in "$WORKSPACES_DIR"/*.env; do
    [[ -e "$file" ]] || continue
    found=1
    name="$(env_value "$file" WORKSPACE_NAME "$(basename "$file" .env)")"
    path="$(env_value "$file" WIKI_WORKSPACE_PATH "-")"
    serve="$(env_value "$file" WIKI_SERVE_PORT "-")"
    mcp="$(env_value "$file" WIKI_MCP_PORT "-")"
    imports="$(env_value "$file" WIKI_IMPORTS "")"
    count=0
    if [[ -n "$imports" ]]; then
      local IFS='|'
      read -r -a _imports <<< "$imports"
      for entry in "${_imports[@]}"; do
        [[ -n "$entry" ]] && count=$((count + 1))
      done
    fi
    printf '%s\tpath=%s\tserve=%s\tmcp=%s\timports=%s\n' "$name" "$path" "$serve" "$mcp" "$count"
  done
  [[ "$found" -eq 1 ]] || printf 'No workspaces configured in %s\n' "$WORKSPACES_DIR"
}

import_paths() {
  local workspace="$1"
  local imports entry
  imports="$(workspace_value "$workspace" WIKI_IMPORTS "")"
  [[ -n "$imports" ]] || return 0
  local IFS='|'
  read -r -a _imports <<< "$imports"
  for entry in "${_imports[@]}"; do
    [[ -n "$entry" ]] && printf '%s\n' "$entry"
  done
}

compose_project() {
  local workspace="$1"
  printf 'wiki-%s' "$workspace" | tr -c '[:alnum:]_-' '-'
}

compose_for_workspace() {
  local workspace="$1"
  shift
  need_workspace_env "$workspace"
  local workspace_env ws_path serve_port mcp_port project
  workspace_env="$(workspace_env_file "$workspace")"
  ws_path="$(normalize_path "$(workspace_value "$workspace" WIKI_WORKSPACE_PATH)")"
  serve_port="$(workspace_value "$workspace" WIKI_SERVE_PORT 3100)"
  mcp_port="$(workspace_value "$workspace" WIKI_MCP_PORT 3101)"
  project="$(compose_project "$workspace")"

  local compose_env_args=()
  [[ -f "$MANAGER_ENV_FILE" ]] && compose_env_args+=(--env-file "$MANAGER_ENV_FILE")
  compose_env_args+=(--env-file "$workspace_env")

  WIKI_WORKSPACE_PATH="$ws_path" \
  WIKI_SERVE_PORT="$serve_port" \
  WIKI_MCP_PORT="$mcp_port" \
  docker compose "${compose_env_args[@]}" -f "$ROOT_DIR/docker-compose.yml" -p "$project" "$@"
}

compose_for_cme() {
  local compose_env_args=()
  [[ -f "$MANAGER_ENV_FILE" ]] && compose_env_args+=(--env-file "$MANAGER_ENV_FILE")
  docker compose "${compose_env_args[@]}" -f "$ROOT_DIR/docker-compose.yml" -p wikillm-cme "$@"
}

compose_for_mailer() {
  local compose_env_args=()
  [[ -f "$MANAGER_ENV_FILE" ]] && compose_env_args+=(--env-file "$MANAGER_ENV_FILE")
  docker compose "${compose_env_args[@]}" -f "$ROOT_DIR/docker-compose.yml" -p wikillm-mailer "$@"
}

logs_args() {
  if [[ $# -eq 0 ]]; then
    printf '%s\n' --tail=100 -f
  else
    printf '%s\n' "$@"
  fi
}

run_wiki() {
  local workspace="$1"
  shift
  compose_for_workspace "$workspace" run --rm wiki "$@"
}

open_app_mode() {
  local url="$1"
  case "$(uname -s)" in
    Darwin)
      open -na "Google Chrome" --args "--app=${url}" 2>/dev/null \
        || open -na "Microsoft Edge" --args "--app=${url}" 2>/dev/null \
        || open -a Safari "${url}" 2>/dev/null \
        || open "${url}"
      ;;
    Linux)
      for candidate in google-chrome google-chrome-stable chromium chromium-browser microsoft-edge microsoft-edge-stable; do
        if command -v "$candidate" >/dev/null 2>&1; then
          "$candidate" "--app=${url}" &
          return
        fi
      done
      xdg-open "${url}" 2>/dev/null || true
      ;;
    MINGW*|MSYS*|CYGWIN*)
      for candidate in \
        "C:/Program Files/Google/Chrome/Application/chrome.exe" \
        "C:/Program Files (x86)/Google/Chrome/Application/chrome.exe" \
        "C:/Program Files (x86)/Microsoft/Edge/Application/msedge.exe" \
        "C:/Program Files/Microsoft/Edge/Application/msedge.exe"; do
        if [[ -f "$candidate" ]]; then
          "$candidate" "--app=${url}" &
          return
        fi
      done
      start "" "${url}" || true
      ;;
  esac
}

wait_and_open() {
  local url="$1"
  local max_attempts=30
  local i=0
  while (( i < max_attempts )); do
    sleep 1
    if curl -sf "${url}" >/dev/null 2>&1; then
      open_app_mode "${url}"
      return
    fi
    (( i++ )) || true
  done
  printf 'wiki-workspace: server did not become ready at %s after %ds, opening anyway\n' "${url}" "$max_attempts" >&2
  open_app_mode "${url}"
}

copy_one_export() {
  local workspace="$1"
  local export_path="$2"
  local ws_path source_abs target_abs

  ws_path="$(normalize_path "$(workspace_value "$workspace" WIKI_WORKSPACE_PATH)")"

  source_abs="$(absolute_path "$export_path")"
  target_abs="$ws_path/raw/untracked"

  [[ -d "$source_abs" ]] || die "export path is not a directory: $source_abs"
  mkdir -p "$target_abs"

  if command -v rsync >/dev/null 2>&1; then
    rsync -a --include='*/' --include='*.md' --exclude='*' "$source_abs/" "$target_abs/"
  else
    find "$source_abs" -type f -name '*.md' -print0 | while IFS= read -r -d '' file; do
      rel="${file#"$source_abs"/}"
      mkdir -p "$target_abs/$(dirname "$rel")"
      cp "$file" "$target_abs/$rel"
    done
  fi

  printf 'Copied %s -> %s\n' "$source_abs" "$target_abs"
}

copy_exports() {
  local workspace="$1"
  local count=0
  local configured_imports=()
  while IFS= read -r export_path; do
    [[ -n "$export_path" ]] || continue
    configured_imports+=("$export_path")
  done < <(import_paths "$workspace")

  if [[ "${#configured_imports[@]}" -eq 0 ]]; then
    printf 'No imports configured for workspace: %s\n' "$workspace"
    return 0
  fi

  for export_path in "${configured_imports[@]}"; do
    copy_one_export "$workspace" "$export_path"
    count=$((count + 1))
  done
}

main() {
  if [[ $# -eq 1 && "$1" =~ ^(-h|--help|help)$ ]]; then
    usage
    exit 0
  fi

  if [[ $# -eq 1 && "$1" == "list" ]]; then
    list_workspaces
    exit 0
  fi

  if [[ $# -ge 2 && "$1" == "cme" ]]; then
    local cme_command="$2"
    shift 2
    case "$cme_command" in
      up)
        [[ $# -eq 0 ]] || die "cme up does not take arguments"
        compose_for_cme up -d cme-mcp
        ;;
      down)
        [[ $# -eq 0 ]] || die "cme down does not take arguments"
        compose_for_cme stop cme-mcp
        ;;
      logs)
        mapfile -t log_args < <(logs_args "$@")
        compose_for_cme logs "${log_args[@]}" cme-mcp
        ;;
      *)
        die "unknown cme command: $cme_command"
        ;;
    esac
    exit 0
  fi

  if [[ $# -ge 2 && "$1" == "mailer" ]]; then
    local mailer_command="$2"
    shift 2
    case "$mailer_command" in
      up)
        [[ $# -eq 0 ]] || die "mailer up does not take arguments"
        compose_for_mailer up -d mailer-mcp
        ;;
      down)
        [[ $# -eq 0 ]] || die "mailer down does not take arguments"
        compose_for_mailer stop mailer-mcp
        ;;
      logs)
        mapfile -t log_args < <(logs_args "$@")
        compose_for_mailer logs "${log_args[@]}" mailer-mcp
        ;;
      *)
        die "unknown mailer command: $mailer_command"
        ;;
    esac
    exit 0
  fi

  [[ $# -ge 2 ]] || { usage; exit 2; }

  local scope="$1"
  [[ "$scope" == "wiki" ]] || die "unknown scope: $scope (expected: wiki, cme, mailer, or list)"
  shift
  [[ $# -ge 2 ]] || die "wiki requires a workspace and a command"

  local workspace="$1"
  local command="$2"
  shift 2

  case "$command" in
    init)
      run_wiki "$workspace" init "$@"
      ;;
    up)
      compose_for_workspace "$workspace" up -d serve mcp-http production-mcp
      compose_for_cme up -d cme-mcp
      compose_for_mailer up -d mailer-mcp
      local serve_port production_port
      serve_port="$(workspace_value "$workspace" WIKI_SERVE_PORT 3100)"
      production_port="$(workspace_value "$workspace" PRODUCTION_MCP_PORT 3336)"
      printf 'Workspace UI: http://localhost:%s\n' "$serve_port"
      printf 'Chat MCP:     http://localhost:%s/chat\n' "$serve_port"
      printf 'Production:   http://localhost:%s/mcp/\n' "$production_port"
      ;;
    down)
      compose_for_workspace "$workspace" down
      ;;
    logs)
      mapfile -t log_args < <(logs_args "$@")
      compose_for_workspace "$workspace" logs "${log_args[@]}" serve mcp-http production-mcp
      ;;
    serve)
      local open_browser=0
      if [[ $# -eq 1 && "$1" == "--open" ]]; then
        open_browser=1
      elif [[ $# -ne 0 ]]; then
        die "serve accepts only --open as optional flag; port is configured in workspaces/<name>.env"
      fi
      printf 'Starting mcp-http...\n'
      compose_for_workspace "$workspace" up -d mcp-http
      printf 'Starting production-mcp...\n'
      compose_for_workspace "$workspace" up -d production-mcp
      printf 'Starting cme-mcp...\n'
      compose_for_cme up -d cme-mcp
      printf 'Starting mailer-mcp...\n'
      compose_for_mailer up -d mailer-mcp
      local serve_port production_port
      serve_port="$(workspace_value "$workspace" WIKI_SERVE_PORT 3100)"
      production_port="$(workspace_value "$workspace" PRODUCTION_MCP_PORT 3336)"
      printf 'Workspace UI: http://localhost:%s\n' "$serve_port"
      printf 'Chat MCP:     http://localhost:%s/chat\n' "$serve_port"
      printf 'Production:   http://localhost:%s/mcp/\n' "$production_port"
      printf 'Note: compose logs may show http://localhost:3000, which is the container port.\n'
      if [[ $open_browser -eq 1 ]]; then
        wait_and_open "http://localhost:${serve_port}" &
      fi
      compose_for_workspace "$workspace" up serve
      ;;
    doctor|ingest|build|export)
      run_wiki "$workspace" "$command" "$@"
      ;;
    copy)
      [[ $# -eq 0 ]] || die "copy does not take an import name; it copies all configured exports for the workspace"
      copy_exports "$workspace"
      ;;
    run)
      [[ $# -gt 0 ]] || die "run requires wiki CLI args"
      run_wiki "$workspace" "$@"
      ;;
    -h|--help|help)
      usage
      ;;
    *)
      die "unknown command: $command"
      ;;
  esac
}

main "$@"
