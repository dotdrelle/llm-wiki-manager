#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WORKSPACES_DIR="${WIKI_WORKSPACES_DIR:-$ROOT_DIR/workspaces}"
MANAGER_ENV_FILE="${WIKI_MANAGER_ENV_FILE:-$ROOT_DIR/.env}"

usage() {
  cat <<'EOF'
Usage:
  ./wiki-workspace config <workspace> [path]
  ./wiki-workspace up <workspace>
  ./wiki-workspace wiki <workspace> <command> [args...]
  ./wiki-workspace cme <workspace> <up|down|logs>
  ./wiki-workspace mailer <up|down|logs>
  ./wiki-workspace list

Commands:
  config <workspace> [path]         Create workspace folder, auto-select ports, run wiki init
  up <workspace>                    Start full stack: wiki + cme + mailer for this workspace
  list                              List configured workspaces

  cme <workspace> up                Start workspace-scoped agent-cme MCP server
  cme <workspace> down              Stop workspace-scoped agent-cme MCP server
  cme <workspace> logs [args...]    Follow workspace-scoped agent-cme logs (tail 100 by default)

  mailer up                         Start the shared agent-mailer-api MCP server
  mailer down                       Stop the shared agent-mailer-api MCP server
  mailer logs [args...]             Follow agent-mailer-api logs (tail 100 by default)

  wiki <workspace> init             Initialize the workspace with wiki init
  wiki <workspace> up               Start llm-wiki serve + mcp-http + production-mcp
  wiki <workspace> down             Stop all services for this workspace
  wiki <workspace> logs [args...]   Follow workspace service logs (tail 100 by default)
  wiki <workspace> serve [--open]   Start the web UI in foreground (--open launches browser)
  wiki <workspace> doctor           Run wiki doctor
  wiki <workspace> ingest           Run wiki ingest
  wiki <workspace> build            Run wiki build
  wiki <workspace> export           Run wiki export
  wiki <workspace> run <args...>    Run arbitrary wiki CLI args

Configuration:
  workspaces/<workspace>/.env
  Override directory: WIKI_WORKSPACES_DIR=/path/to/dir
EOF
}

die() {
  printf 'Error: %s\n' "$*" >&2
  exit 1
}

normalize_path() {
  local value="$1"
  if command -v wslpath >/dev/null 2>&1 && [[ "$value" =~ ^[A-Za-z]:[\\/] ]]; then
    wslpath -u "$value"
    return
  fi
  printf '%s\n' "$value"
}

absolute_path() {
  local value="$1"
  value="$(normalize_path "$value")"
  if [[ "$value" = /* ]]; then
    printf '%s\n' "$value"
  else
    printf '%s\n' "$ROOT_DIR/$value"
  fi
}

workspace_env_file() {
  local workspace="$1"
  printf '%s/%s/.env\n' "$WORKSPACES_DIR" "$workspace"
}

need_workspace_env() {
  local workspace="$1"
  local file
  file="$(workspace_env_file "$workspace")"
  [[ -f "$file" ]] || die "missing workspace env: $file — run: ./wiki-workspace config $workspace"
}

env_value() {
  local file="$1"
  local key="$2"
  local default="${3-}"
  local line value
  [[ -f "$file" ]] || { printf '%s\n' "$default"; return 0; }
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line%$'\r'}"
    [[ "$line" == "$key="* ]] || continue
    value="${line#*=}"
    if [[ "$value" == \"*\" && "$value" == *\" ]]; then
      value="${value:1:${#value}-2}"
    elif [[ "$value" == \'*\' && "$value" == *\' ]]; then
      value="${value:1:${#value}-2}"
    fi
    printf '%s\n' "$value"
    return 0
  done < "$file"
  printf '%s\n' "$default"
}

workspace_value() {
  local workspace="$1"
  local key="$2"
  local default="${3-}"
  env_value "$(workspace_env_file "$workspace")" "$key" "$default"
}

used_workspace_ports() {
  local entry file key val
  for entry in "$WORKSPACES_DIR"/*; do
    [[ -d "$entry" ]] || continue
    file="$entry/.env"
    [[ -f "$file" ]] || continue
    for key in WIKI_SERVE_PORT WIKI_MCP_PORT CME_MCP_PORT PRODUCTION_MCP_PORT; do
      val="$(env_value "$file" "$key" "")"
      [[ "$val" =~ ^[0-9]+$ ]] && printf '%s\n' "$val"
    done
  done
  if [[ -f "$MANAGER_ENV_FILE" ]]; then
    val="$(env_value "$MANAGER_ENV_FILE" MAILER_MCP_PORT "")"
    [[ "$val" =~ ^[0-9]+$ ]] && printf '%s\n' "$val"
  fi
}

is_port_in_use() {
  local port="$1"
  if command -v lsof >/dev/null 2>&1; then
    lsof -iTCP:"$port" -sTCP:LISTEN >/dev/null 2>&1
  else
    (echo >/dev/tcp/127.0.0.1/"$port") 2>/dev/null
  fi
}

find_free_port() {
  local start="${1:-3100}"
  local port="$start"
  local used_ports=()
  read_lines_into_array used_ports used_workspace_ports
  while true; do
    local taken=0 p
    for p in "${used_ports[@]}"; do
      [[ "$p" == "$port" ]] && { taken=1; break; }
    done
    if [[ "$taken" -eq 0 ]] && ! is_port_in_use "$port"; then
      printf '%s\n' "$port"
      return 0
    fi
    port=$((port + 1))
  done
}

list_workspaces() {
  [[ -d "$WORKSPACES_DIR" ]] || die "missing workspaces directory: $WORKSPACES_DIR"
  local found=0 entry file name path serve mcp cme prod

  for entry in "$WORKSPACES_DIR"/*; do
    [[ -d "$entry" ]] || continue
    file="$entry/.env"
    [[ -f "$file" ]] || continue
    found=1
    name="$(env_value "$file" WORKSPACE_NAME "$(basename "$entry")")"
    path="$(env_value "$file" WIKI_WORKSPACE_PATH "-")"
    serve="$(env_value "$file" WIKI_SERVE_PORT "-")"
    mcp="$(env_value "$file" WIKI_MCP_PORT "-")"
    cme="$(env_value "$file" CME_MCP_PORT "-")"
    prod="$(env_value "$file" PRODUCTION_MCP_PORT "-")"
    printf '%s\tpath=%s\tserve=%s\tmcp=%s\tcme=%s\tprod=%s\n' \
      "$name" "$path" "$serve" "$mcp" "$cme" "$prod"
  done

  [[ "$found" -eq 1 ]] || printf 'No workspaces configured in %s\n' "$WORKSPACES_DIR"
}

compose_project() {
  local workspace="$1"
  printf 'wiki-%s' "$workspace" | tr -c '[:alnum:]_-' '-'
}

compose_for_workspace() {
  local workspace="$1"
  shift
  need_workspace_env "$workspace"
  local workspace_env ws_path serve_port mcp_port cme_port project
  workspace_env="$(workspace_env_file "$workspace")"
  ws_path="$(normalize_path "$(workspace_value "$workspace" WIKI_WORKSPACE_PATH)")"
  serve_port="$(workspace_value "$workspace" WIKI_SERVE_PORT 3100)"
  mcp_port="$(workspace_value "$workspace" WIKI_MCP_PORT 3101)"
  cme_port="$(workspace_value "$workspace" CME_MCP_PORT 3102)"
  project="$(compose_project "$workspace")"

  local compose_env_args=()
  [[ -f "$MANAGER_ENV_FILE" ]] && compose_env_args+=(--env-file "$MANAGER_ENV_FILE")
  compose_env_args+=(--env-file "$workspace_env")

  WIKI_WORKSPACE_PATH="$ws_path" \
  WIKI_SERVE_PORT="$serve_port" \
  WIKI_MCP_PORT="$mcp_port" \
  CME_MCP_PORT="$cme_port" \
  docker compose "${compose_env_args[@]}" -f "$ROOT_DIR/docker-compose.yml" -p "$project" "$@"
}

compose_for_mailer() {
  local compose_env_args=()
  [[ -f "$MANAGER_ENV_FILE" ]] && compose_env_args+=(--env-file "$MANAGER_ENV_FILE")
  docker compose "${compose_env_args[@]}" -f "$ROOT_DIR/docker-compose.yml" -p wikillm-mailer "$@"
}

logs_args() {
  if [[ $# -eq 0 ]]; then
    printf '%s\n' --tail=100 -f
  else
    printf '%s\n' "$@"
  fi
}

read_lines_into_array() {
  local array_name="$1"
  shift
  local line
  eval "$array_name=()"
  while IFS= read -r line; do
    eval "$array_name+=(\"\$line\")"
  done < <("$@")
}

run_wiki() {
  local workspace="$1"
  shift
  compose_for_workspace "$workspace" run --rm wiki "$@"
}

open_app_mode() {
  local url="$1"
  case "$(uname -s)" in
    Darwin)
      open -na "Google Chrome" --args "--app=${url}" 2>/dev/null \
        || open -na "Microsoft Edge" --args "--app=${url}" 2>/dev/null \
        || open -a Safari "${url}" 2>/dev/null \
        || open "${url}"
      ;;
    Linux)
      for candidate in google-chrome google-chrome-stable chromium chromium-browser microsoft-edge microsoft-edge-stable; do
        if command -v "$candidate" >/dev/null 2>&1; then
          "$candidate" "--app=${url}" &
          return
        fi
      done
      xdg-open "${url}" 2>/dev/null || true
      ;;
    MINGW*|MSYS*|CYGWIN*)
      for candidate in \
        "C:/Program Files/Google/Chrome/Application/chrome.exe" \
        "C:/Program Files (x86)/Google/Chrome/Application/chrome.exe" \
        "C:/Program Files (x86)/Microsoft/Edge/Application/msedge.exe" \
        "C:/Program Files/Microsoft/Edge/Application/msedge.exe"; do
        if [[ -f "$candidate" ]]; then
          "$candidate" "--app=${url}" &
          return
        fi
      done
      start "" "${url}" || true
      ;;
  esac
}

wait_and_open() {
  local url="$1"
  local max_attempts=30
  local i=0
  while (( i < max_attempts )); do
    sleep 1
    if curl -sf "${url}" >/dev/null 2>&1; then
      open_app_mode "${url}"
      return
    fi
    (( i++ )) || true
  done
  printf 'wiki-workspace: server did not become ready at %s after %ds, opening anyway\n' "${url}" "$max_attempts" >&2
  open_app_mode "${url}"
}

ensure_workspace_dirs() {
  local ws_path="$1"
  mkdir -p "$ws_path/.cme"
  mkdir -p "$ws_path/raw/untracked"
}

register_workspace_path() {
  local workspace="$1"
  local target_path="$2"
  local registry_path registry_abs
  registry_path="$WORKSPACES_DIR/$workspace"
  registry_abs="$(absolute_path "$registry_path")"

  [[ "$target_path" == "$registry_abs" ]] && return 0

  mkdir -p "$WORKSPACES_DIR"
  if [[ -e "$registry_path" || -L "$registry_path" ]]; then
    die "workspace registry path already exists: $registry_path"
  fi
  ln -s "$target_path" "$registry_path"
  printf 'Registered %s -> %s\n' "$registry_path" "$target_path"
}

config_workspace() {
  local workspace="$1"
  local target_path="${2:-$WORKSPACES_DIR/$workspace}"
  target_path="$(absolute_path "$target_path")"

  local env_file="$target_path/.env"
  [[ -f "$env_file" ]] && die "workspace already configured: $env_file"

  local serve_port mcp_port cme_port prod_port
  serve_port="$(find_free_port 3100)"
  mcp_port="$(find_free_port $((serve_port + 1)))"
  cme_port="$(find_free_port $((mcp_port + 1)))"
  prod_port="$(find_free_port $((cme_port + 1)))"

  mkdir -p "$target_path"
  register_workspace_path "$workspace" "$target_path"
  ensure_workspace_dirs "$target_path"

  printf 'WORKSPACE_NAME=%s\nWIKI_WORKSPACE_PATH=%s\nWIKI_SERVE_PORT=%s\nWIKI_MCP_PORT=%s\nCME_MCP_PORT=%s\nPRODUCTION_MCP_PORT=%s\n' \
    "$workspace" "$target_path" "$serve_port" "$mcp_port" "$cme_port" "$prod_port" \
    > "$env_file"

  printf 'Created %s\n' "$env_file"
  printf 'Ports  serve=%s  mcp=%s  cme=%s  production=%s\n' \
    "$serve_port" "$mcp_port" "$cme_port" "$prod_port"

  local compose_env_args=()
  [[ -f "$MANAGER_ENV_FILE" ]] && compose_env_args+=(--env-file "$MANAGER_ENV_FILE")
  compose_env_args+=(--env-file "$env_file")

  WIKI_WORKSPACE_PATH="$target_path" \
  WIKI_SERVE_PORT="$serve_port" \
  WIKI_MCP_PORT="$mcp_port" \
  CME_MCP_PORT="$cme_port" \
    docker compose "${compose_env_args[@]}" -f "$ROOT_DIR/docker-compose.yml" run --rm wiki init

  printf 'Workspace ready: %s\n' "$target_path"
  printf 'Start with:      ./wiki-workspace up %s\n' "$workspace"
}

up_workspace() {
  local workspace="$1"
  local ws_path
  ws_path="$(normalize_path "$(workspace_value "$workspace" WIKI_WORKSPACE_PATH)")"
  ensure_workspace_dirs "$ws_path"

  compose_for_workspace "$workspace" up -d serve mcp-http production-mcp cme-mcp
  compose_for_mailer up -d mailer-mcp

  local serve_port cme_port prod_port
  serve_port="$(workspace_value "$workspace" WIKI_SERVE_PORT 3100)"
  cme_port="$(workspace_value "$workspace" CME_MCP_PORT 3102)"
  prod_port="$(workspace_value "$workspace" PRODUCTION_MCP_PORT 3103)"
  printf 'Workspace UI: http://localhost:%s\n' "$serve_port"
  printf 'Chat:         http://localhost:%s/chat\n' "$serve_port"
  printf 'CME MCP:      http://localhost:%s/mcp/\n' "$cme_port"
  printf 'Production:   http://localhost:%s/mcp/\n' "$prod_port"
}

main() {
  if [[ $# -eq 1 && "$1" =~ ^(-h|--help|help)$ ]]; then
    usage
    exit 0
  fi

  if [[ $# -eq 1 && "$1" == "list" ]]; then
    list_workspaces
    exit 0
  fi

  # config <workspace> [path]
  if [[ $# -ge 2 && "$1" == "config" ]]; then
    local cfg_workspace="$2"
    local cfg_path="${3:-}"
    if [[ -n "$cfg_path" ]]; then
      config_workspace "$cfg_workspace" "$cfg_path"
    else
      config_workspace "$cfg_workspace"
    fi
    exit 0
  fi

  # up <workspace>
  if [[ $# -eq 2 && "$1" == "up" ]]; then
    up_workspace "$2"
    exit 0
  fi

  # cme <workspace> <command>
  if [[ $# -ge 1 && "$1" == "cme" ]]; then
    [[ $# -ge 3 ]] || die "usage: ./wiki-workspace cme <workspace> <up|down|logs>"
    local cme_workspace="$2"
    local cme_command="$3"
    shift 3
    case "$cme_command" in
      up)
        [[ $# -eq 0 ]] || die "cme up does not take arguments"
        local ws_path
        ws_path="$(normalize_path "$(workspace_value "$cme_workspace" WIKI_WORKSPACE_PATH)")"
        ensure_workspace_dirs "$ws_path"
        compose_for_workspace "$cme_workspace" up -d cme-mcp
        local cme_port
        cme_port="$(workspace_value "$cme_workspace" CME_MCP_PORT 3102)"
        printf 'CME MCP: http://localhost:%s/mcp/\n' "$cme_port"
        ;;
      down)
        [[ $# -eq 0 ]] || die "cme down does not take arguments"
        compose_for_workspace "$cme_workspace" stop cme-mcp
        ;;
      logs)
        local log_args=()
        read_lines_into_array log_args logs_args "$@"
        compose_for_workspace "$cme_workspace" logs "${log_args[@]}" cme-mcp
        ;;
      *)
        die "unknown cme command: $cme_command (expected: up, down, logs)"
        ;;
    esac
    exit 0
  fi

  # mailer <command>
  if [[ $# -ge 2 && "$1" == "mailer" ]]; then
    local mailer_command="$2"
    shift 2
    case "$mailer_command" in
      up)
        [[ $# -eq 0 ]] || die "mailer up does not take arguments"
        compose_for_mailer up -d mailer-mcp
        ;;
      down)
        [[ $# -eq 0 ]] || die "mailer down does not take arguments"
        compose_for_mailer stop mailer-mcp
        ;;
      logs)
        local log_args=()
        read_lines_into_array log_args logs_args "$@"
        compose_for_mailer logs "${log_args[@]}" mailer-mcp
        ;;
      *)
        die "unknown mailer command: $mailer_command"
        ;;
    esac
    exit 0
  fi

  [[ $# -ge 2 ]] || { usage; exit 2; }

  local scope="$1"
  [[ "$scope" == "wiki" ]] || die "unknown scope: $scope (expected: wiki, cme, mailer, up, config, or list)"
  shift
  [[ $# -ge 2 ]] || die "wiki requires a workspace and a command"

  local workspace="$1"
  local command="$2"
  shift 2

  case "$command" in
    init)
      run_wiki "$workspace" init "$@"
      ;;
    up)
      compose_for_workspace "$workspace" up -d serve mcp-http production-mcp
      local serve_port production_port
      serve_port="$(workspace_value "$workspace" WIKI_SERVE_PORT 3100)"
      production_port="$(workspace_value "$workspace" PRODUCTION_MCP_PORT 3103)"
      printf 'Workspace UI: http://localhost:%s\n' "$serve_port"
      printf 'Chat MCP:     http://localhost:%s/chat\n' "$serve_port"
      printf 'Production:   http://localhost:%s/mcp/\n' "$production_port"
      printf 'Tip: use ./wiki-workspace up %s to also start CME and mailer.\n' "$workspace"
      ;;
    down)
      compose_for_workspace "$workspace" down
      ;;
    logs)
      local log_args=()
      read_lines_into_array log_args logs_args "$@"
      compose_for_workspace "$workspace" logs "${log_args[@]}" serve mcp-http production-mcp
      ;;
    serve)
      local open_browser=0
      if [[ $# -eq 1 && "$1" == "--open" ]]; then
        open_browser=1
      elif [[ $# -ne 0 ]]; then
        die "serve accepts only --open as optional flag; port is configured in the workspace .env"
      fi
      printf 'Starting mcp-http...\n'
      compose_for_workspace "$workspace" up -d mcp-http
      printf 'Starting production-mcp...\n'
      compose_for_workspace "$workspace" up -d production-mcp
      local serve_port production_port
      serve_port="$(workspace_value "$workspace" WIKI_SERVE_PORT 3100)"
      production_port="$(workspace_value "$workspace" PRODUCTION_MCP_PORT 3103)"
      printf 'Workspace UI: http://localhost:%s\n' "$serve_port"
      printf 'Chat MCP:     http://localhost:%s/chat\n' "$serve_port"
      printf 'Production:   http://localhost:%s/mcp/\n' "$production_port"
      printf 'Note: compose logs may show http://localhost:3000, which is the container port.\n'
      if [[ $open_browser -eq 1 ]]; then
        wait_and_open "http://localhost:${serve_port}" &
      fi
      compose_for_workspace "$workspace" up serve
      ;;
    doctor|ingest|build|export)
      run_wiki "$workspace" "$command" "$@"
      ;;
    run)
      [[ $# -gt 0 ]] || die "run requires wiki CLI args"
      run_wiki "$workspace" "$@"
      ;;
    -h|--help|help)
      usage
      ;;
    *)
      die "unknown command: $command"
      ;;
  esac
}

main "$@"
