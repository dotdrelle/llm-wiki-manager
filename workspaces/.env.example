# Workspace-local configuration.
# Copy this file to workspaces/<name>.env.

WORKSPACE_NAME=example
WIKI_WORKSPACE_PATH=/absolute/path/to/llm-wiki-workspace

# Host ports exposed by this workspace.
WIKI_SERVE_PORT=3100
WIKI_MCP_PORT=3101

# Optional production agent port for this workspace.
PRODUCTION_MCP_PORT=3336

# Optional copy imports. Use | to separate several directories.
# Paths may be absolute or relative to llm-wiki-manager.
WIKI_IMPORTS=../agent-cme/data/exports/export-directory

# Optional import path mapping for agent-wiki-production containers.
PRODUCTION_IMPORT_PATH_MAPPINGS=../agent-cme/data=/agent-cme-data
