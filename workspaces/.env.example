# Workspace configuration.
# New format: save as workspaces/<name>/.env
# Run ./wiki-workspace config <name> [path] to generate this automatically.

WORKSPACE_NAME=example
WIKI_WORKSPACE_PATH=/absolute/path/to/workspace

# Host ports for this workspace. Each workspace must use unique ports.
# Use ./wiki-workspace config to auto-assign free ports.
WIKI_SERVE_PORT=3100
WIKI_MCP_PORT=3101
CME_MCP_PORT=3102
PRODUCTION_MCP_PORT=3103

# Workspace-scoped bearer tokens for MCP endpoints.
# Generated automatically by ./wiki-workspace config.
WIKI_MCP_AUTH_TOKEN=
CME_MCP_AUTH_TOKEN=
PRODUCTION_MCP_AUTH_TOKEN=
